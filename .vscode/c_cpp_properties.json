{
    "configurations": [
        {
            "name": "KEYHAN",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/include/",
                "${env:IDF_PATH}/components/**",
                "${env:IDF_PATH}/components/freertos/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/**",
                    "${workspaceFolder}/include/*",
                    "${env:IDF_PATH}/components/**",
                    "${env:IDF_PATH}/components/freertos/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            },
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}